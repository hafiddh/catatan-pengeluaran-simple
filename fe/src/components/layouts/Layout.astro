---
import "@/assets/styles/style.css";
import { ClientRouter } from "astro:transitions";
import imgFavicon from "/favicon.ico";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content=`${description} - Pencatatan Pengeluaran - AngelSuicide`
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="shortcut icon" href={imgFavicon} />
    <link rel="apple-touch-icon" href={imgFavicon} />

    <meta name="generator" content={Astro.generator} />
    <title>{title} - Pencatatan Pengeluaran</title>
    <script is:inline>
      (() => {
        try {
          const storageKey = "theme-preference";
          const root = document.documentElement;
          const saved = localStorage.getItem(storageKey);

          const applyTheme = (isDark) => {
            const theme = isDark ? "dark" : "light";
            root.classList.toggle("dark", isDark);
            root.setAttribute("data-theme", theme);
          };

          const mq = window.matchMedia("(prefers-color-scheme: dark)");

          // If user has explicitly saved preference, respect it.
          if (saved === "light" || saved === "dark") {
            applyTheme(saved === "dark");
          } else {
            // No saved preference — default to dark on first load
            try {
              localStorage.setItem(storageKey, "dark");
            } catch (e) {}
            applyTheme(true);
          }

          // Listen for changes in device preference and update if no saved preference
          try {
            mq.addEventListener
              ? mq.addEventListener("change", (e) => {
                  if (
                    !(
                      localStorage.getItem(storageKey) === "light" ||
                      localStorage.getItem(storageKey) === "dark"
                    )
                  ) {
                    applyTheme(e.matches);
                  }
                })
              : mq.addListener((e) => {
                  if (
                    !(
                      localStorage.getItem(storageKey) === "light" ||
                      localStorage.getItem(storageKey) === "dark"
                    )
                  ) {
                    applyTheme(e.matches);
                  }
                });
          } catch (e) {}
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <slot />
    <noscript>
      <div class="text-center">
        <strong class="h5 text-danger"
          >Your browser does not support JavaScript!</strong
        >
      </div>
    </noscript>

    <script is:inline>
      (() => {
        try {
          const img = document.getElementById("mobile-profile-img");
          const pic = localStorage.getItem("auth_user.picture") || "";
          if (img && pic) {
            img.setAttribute("src", pic);
          } else if (img) {
            img.setAttribute("src", "");
          }
        } catch (e) {
          // ignore
        }
      })();
    </script>
  </body>
</html>
