---
import Layout from "@/components/layouts/Layout.astro";
import { LoginWithGoogleProvider } from "@/components/modules/login/login-with-google-provider";
---

<Layout title="Login" description="Pencatatan Pengeluaran - AngelSuicide">
  <script is:inline>
    (() => {
      try { 
        const token = localStorage.getItem("auth_token");
        const refreshToken = localStorage.getItem("auth_refresh_token");
        if (token || refreshToken) {
          window.location.href = "/dashboard";
          return;
        }
      } catch {}
    })();
  </script>
  <LoginWithGoogleProvider client:load />
</Layout>
