---
import "@/assets/styles/style.css";
import { ClientRouter } from "astro:transitions";
import imgFavicon from "/favicon.ico";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content=`${description} - Pencatatan Pengeluaran - AngelSuicide`
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <!-- <link
			rel="icon"
			href="https://www.bkn.go.id/unggahan/2024/04/favicon32.png"
			sizes="32x32"
		/>
		<link
			rel="shortcut icon"
			href="https://www.bkn.go.id/unggahan/2024/04/favicon32.png"
		/>
		<link
			rel="apple-touch-icon"
			href="https://www.bkn.go.id/unggahan/2024/04/favicon57.png"
			sizes="57x57"
		/>
		<link
			rel="apple-touch-icon"
			href="https://www.bkn.go.id/unggahan/2024/04/favicon76.png"
			sizes="76x76"
		/>
		<link
			rel="apple-touch-icon"
			href="https://www.bkn.go.id/unggahan/2024/04/favicon120.png"
			sizes="120x120"
		/>
		<link
			rel="apple-touch-icon"
			href="https://www.bkn.go.id/unggahan/2024/04/favicon152.png"
			sizes="114x114"
		/> -->
    <link rel="shortcut icon" href={imgFavicon} />
    <link rel="apple-touch-icon" href={imgFavicon} />

    <meta name="generator" content={Astro.generator} />
    <title>{title} - Pencatatan Pengeluaran</title>
    <script is:inline>
      (() => {
        const storageKey = "theme-preference";
        const root = document.documentElement;
        const saved = localStorage.getItem(storageKey);
        const preferDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const theme =
          saved === "light" || saved === "dark"
            ? saved
            : preferDark
              ? "dark"
              : "light";

        root.classList.toggle("dark", theme === "dark");
        root.setAttribute("data-theme", theme);
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <slot />
    <button
      type="button"
      id="theme-toggle"
      class="theme-toggle"
      aria-label="Toggle tema"
    >
    </button>
    <script is:inline>
      (() => {
        const storageKey = "theme-preference";
        const root = document.documentElement;
        const button = document.getElementById("theme-toggle");

        if (!button) return;

        const sunIcon = `
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364l-1.414 1.414M6.05 17.95l-1.414 1.414m0-12.728l1.414 1.414M17.95 17.95l1.414 1.414M12 7a5 5 0 100 10 5 5 0 000-10z" />
          </svg>
        `;
        const moonIcon = `
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
          </svg>
        `;
        const syncButton = () => {
          const isDark = root.classList.contains("dark");
          button.innerHTML = isDark ? moonIcon : sunIcon;
          button.setAttribute(
            "aria-label",
            isDark ? "Switch to light theme" : "Switch to dark theme",
          );
        };

        const applyTheme = (theme) => {
          const isDark = theme === "dark";
          root.classList.toggle("dark", isDark);
          root.setAttribute("data-theme", theme);
          localStorage.setItem(storageKey, theme);
          syncButton();
        };

        button.addEventListener("click", () => {
          const nextTheme = root.classList.contains("dark") ? "light" : "dark";
          applyTheme(nextTheme);
        });

        syncButton();
      })();
    </script>
    <noscript>
      <div class="text-center">
        <strong class="h5 text-danger"
          >Your browser does not support JavaScript!</strong
        >
      </div>
    </noscript>
  </body>
</html>
